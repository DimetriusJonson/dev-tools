{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Developers tools",
  "version": "0.1.0",
  "identifier": "com.shz.app.dev-tools",
  "build": {
    "beforeDevCommand": "cargo leptos watch",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cargo leptos build --release"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "url": "http://localhost:3005",
        "title": "Developers tools",
        "width": 1500,
        "height": 1000,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": [
      "../site/pkg/"
    ]
  }
}
