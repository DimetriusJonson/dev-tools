{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebDev Useful Tools",
  "version": "0.4.0",
  "identifier": "com.shz.app.WebDevUsefulTools",
  "build": {
    "beforeDevCommand": "cargo leptos watch",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cargo leptos build --release"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": [
      "../site/pkg/"
    ],
    "externalBin": [
      "binaries/webdev_useful_tools_server"
    ]
  }
}
